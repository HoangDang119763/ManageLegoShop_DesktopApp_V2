<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIcon?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0" styleClass="white-bg" stylesheets="@../css/base.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.AttendanceTabController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <top>
                <VBox spacing="10.0" style="-fx-background-color: #f8f9fa;">
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Label text="QUẢN LÝ CHẤM CÔNG HỆ THỐNG" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1f7d84;"/>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="btnDownloadTemplate" styleClass="action-btn" text="TẢI TEMPLATE">
                                    <graphic><FontAwesomeIcon glyphName="DOWNLOAD" /></graphic>
                                </Button>
                                <Button fx:id="btnImport" styleClass="action-btn" text="IMPORT EXCEL">
                                    <graphic><FontAwesomeIcon glyphName="FILE_EXCEL_ALT" /></graphic>
                                </Button>
                                <Button fx:id="btnExport" styleClass="action-btn" text="XUẤT BÁO CÁO">
                                    <graphic><FontAwesomeIcon glyphName="EXTERNAL_LINK" /></graphic>
                                </Button>
                                <Button fx:id="btnRefresh" styleClass="action-btn" text="LÀM MỚI">
                                    <graphic><FontAwesomeIcon glyphName="REFRESH" /></graphic>
                                </Button>
                            </children>
                        </HBox>
                        
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <TextField fx:id="txtSearchEmployee" prefWidth="220.0" promptText="Tìm theo tên hoặc mã NV..." styleClass="textfield" />
                                <ComboBox fx:id="cbDepartment" prefWidth="140.0" promptText="Phòng ban" />
                                
                                <Separator orientation="VERTICAL" />
                                
                                <Label text="Ngày:" style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="cbDay" prefWidth="65.0" />
                                
                                <Label text="Tháng:" style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="cbMonth" prefWidth="65.0" />
                                
                                <Label text="Năm:" style="-fx-font-weight: bold;" />
                                <ComboBox fx:id="cbYear" prefWidth="85.0" />
                                
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblEmployeeName" style="-fx-font-style: italic;" text="NV: Chưa chọn" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </top>

            <center>
                <VBox spacing="10.0">
                    <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                    <children>
                        <HBox spacing="15.0">
                            <children>
                                <VBox style="-fx-background-color: #e3f2fd; -fx-padding: 10; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Nhân sự đi làm" style="-fx-text-fill: #1976d2; -fx-font-weight: bold;" />
                                        <Label fx:id="lblStatPresent" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                                    </children>
                                </VBox>
                                <VBox style="-fx-background-color: #f1f8e9; -fx-padding: 10; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Tổng giờ công" style="-fx-text-fill: #388e3c; -fx-font-weight: bold;" />
                                        <Label fx:id="lblTotalHours" text="0.0 giờ" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                                    </children>
                                </VBox>
                                <VBox style="-fx-background-color: #fff3e0; -fx-padding: 10; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Tổng giờ OT" style="-fx-text-fill: #f57c00; -fx-font-weight: bold;" />
                                        <Label fx:id="lblOTHours" text="0.0 giờ" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                                    </children>
                                </VBox>
                                <VBox style="-fx-background-color: #fafafa; -fx-padding: 10; -fx-border-color: #ddd; -fx-border-radius: 8; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Số dòng dữ liệu" style="-fx-text-fill: #616161; -fx-font-weight: bold;" />
                                        <Label fx:id="lblWorkDays" text="0 dòng" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <TableView fx:id="tblAttendance" tableMenuButtonVisible="true" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60.0" text="Mã NV" />
                                <TableColumn fx:id="colName" prefWidth="180.0" text="Họ tên" />
                                <TableColumn fx:id="colCheckIn" prefWidth="130.0" text="Thời gian vào" />
                                <TableColumn fx:id="colCheckOut" prefWidth="130.0" text="Thời gian ra" />
                                <TableColumn fx:id="colWorkHours" prefWidth="90.0" text="Số giờ công" />
                                <TableColumn fx:id="colOTHours" prefWidth="90.0" text="Giờ OT" />
                                <TableColumn fx:id="colStatus" prefWidth="120.0" text="Trạng thái" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Label fx:id="lblPageInfo" text="Trang 1 / 1" />
                                <Button fx:id="btnPrevious" styleClass="btn-page" text="&lt;" />
                                <Button fx:id="btnNext" styleClass="btn-page" text="&gt;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>