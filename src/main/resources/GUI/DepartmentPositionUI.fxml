<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIcon?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0" prefWidth="1074.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="GUI.DepartmentPositionController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0"
                    AnchorPane.topAnchor="0.0">
            <!-- Top search + refresh bar -->
            <top>
                <AnchorPane prefHeight="50.0" BorderPane.alignment="CENTER">
                    <children>
                        <AnchorPane prefHeight="50.0"
                                    AnchorPane.bottomAnchor="0.0"
                                    AnchorPane.leftAnchor="0.0"
                                    AnchorPane.rightAnchor="0.0"
                                    AnchorPane.topAnchor="0.0">
                            <children>
                                <!-- Left search: Department -->
                                <FontAwesomeIcon fill="#58c9c9"
                                                 glyphName="SEARCH"
                                                 size="1.8em"
                                                 AnchorPane.leftAnchor="365.0"
                                                 AnchorPane.topAnchor="15.0"/>
                                <Line endX="79.0"
                                      startX="-100.0"
                                      stroke="#58c9c9"
                                      AnchorPane.leftAnchor="10.0"
                                      AnchorPane.topAnchor="45.0"/>
                                <TextField fx:id="txtSearchDepartment"
                                           promptText="Tìm kiếm phòng ban..."
                                           styleClass="textfield"
                                           stylesheets="@../css/base.css"
                                           AnchorPane.leftAnchor="10.0"
                                           AnchorPane.topAnchor="15.0"
                                           prefWidth="380.0"/>

                                <!-- Right search: Position -->
                                <FontAwesomeIcon fill="#58c9c9"
                                                 glyphName="SEARCH"
                                                 size="1.8em"
                                                 AnchorPane.leftAnchor="745.0"
                                                 AnchorPane.topAnchor="15.0"/>
                                <Line endX="79.0"
                                      startX="-100.0"
                                      stroke="#58c9c9"
                                      AnchorPane.leftAnchor="390.0"
                                      AnchorPane.topAnchor="45.0"/>
                                <TextField fx:id="txtSearchPosition"
                                           promptText="Tìm kiếm chức vụ..."
                                           styleClass="textfield"
                                           stylesheets="@../css/base.css"
                                           AnchorPane.leftAnchor="390.0"
                                           AnchorPane.topAnchor="15.0"
                                           prefWidth="380.0"/>

                                <!-- Refresh button aligned with search fields -->
                                <Button fx:id="btnDeptRefresh"
                                        text="Làm mới"
                                        prefHeight="35.0" prefWidth="110.0"
                                        styleClass="action-btn"
                                        stylesheets="@../css/base.css"
                                        AnchorPane.rightAnchor="10.0"
                                        AnchorPane.topAnchor="10.0">
                                    <font>
                                        <Font size="14.0"/>
                                    </font>
                                </Button>
                            </children>
                        </AnchorPane>
                    </children>
                </AnchorPane>
            </top>

            <!-- Center: white card with 2 tables -->
            <center>
                <AnchorPane BorderPane.alignment="CENTER">
                    <children>
                        <AnchorPane layoutX="10.0" layoutY="5.0"
                                    stylesheets="@../css/base.css"
                                    AnchorPane.bottomAnchor="5.0"
                                    AnchorPane.leftAnchor="10.0"
                                    AnchorPane.rightAnchor="10.0"
                                    AnchorPane.topAnchor="5.0">
                            <styleClass>
                                <String fx:value="white-bg"/>
                                <String fx:value="shadow"/>
                            </styleClass>
                            <children>
                                <HBox spacing="10.0"
                                      AnchorPane.bottomAnchor="0.0"
                                      AnchorPane.leftAnchor="0.0"
                                      AnchorPane.rightAnchor="0.0"
                                      AnchorPane.topAnchor="0.0">
                                    <children>
                                        <!-- Department panel -->
                                        <VBox spacing="8.0" prefWidth="420.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <TableView fx:id="tblDepartment"
                                                           prefHeight="420.0"
                                                           prefWidth="400.0">
                                                    <columns>
                                                        <TableColumn fx:id="colDeptId" text="Mã phòng ban" prefWidth="90.0"/>
                                                        <TableColumn fx:id="colDeptName" text="Tên phòng ban" prefWidth="180.0"/>
                                                        <TableColumn fx:id="colDeptDescription" text="Mô tả" prefWidth="200.0"/>
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>

                                        <!-- Position panel -->
                                        <VBox spacing="8.0" prefWidth="420.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <TableView fx:id="tblPosition"
                                                           prefHeight="420.0"
                                                           prefWidth="400.0">
                                                    <columns>
                                                        <TableColumn fx:id="colPosId" text="Mã CV" prefWidth="80.0"/>
                                                        <TableColumn fx:id="colPosName" text="Tên chức vụ" prefWidth="200.0"/>
                                                        <TableColumn fx:id="colPosWage" text="Lương cơ bản" prefWidth="120.0"/>
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                                    </columnResizePolicy>
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </children>
                </AnchorPane>
            </center>

            <!-- Bottom: action buttons -->
            <bottom>
                <AnchorPane prefHeight="50.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                    <children>
                        <AnchorPane prefHeight="50.0" prefWidth="880.0"
                                    AnchorPane.bottomAnchor="0.0"
                                    AnchorPane.leftAnchor="0.0"
                                    AnchorPane.rightAnchor="0.0"
                                    AnchorPane.topAnchor="0.0">
                            <children>
                                <!-- Left function buttons for Department (không còn nút Làm mới ở đây) -->
                                <HBox spacing="10.0"
                                      AnchorPane.bottomAnchor="8.0"
                                      AnchorPane.leftAnchor="10.0">
                                    <children>
                                        <Button fx:id="btnDeptAdd"
                                                text="Thêm phòng ban"
                                                prefHeight="35.0" prefWidth="130.0"
                                                styleClass="action-btn"
                                                stylesheets="@../css/base.css">
                                            <font>
                                                <Font size="14.0"/>
                                            </font>
                                        </Button>
                                        <Button fx:id="btnDeptEdit"
                                                text="Sửa phòng ban"
                                                prefHeight="35.0" prefWidth="130.0"
                                                styleClass="action-btn"
                                                stylesheets="@../css/base.css">
                                            <font>
                                                <Font size="14.0"/>
                                            </font>
                                        </Button>
                                        <Button fx:id="btnDeptDelete"
                                                text="Xóa phòng ban"
                                                prefHeight="35.0" prefWidth="130.0"
                                                styleClass="action-btn"
                                                stylesheets="@../css/base.css">
                                            <font>
                                                <Font size="14.0"/>
                                            </font>
                                        </Button>
                                    </children>
                                </HBox>

                                <!-- Right function buttons for Position -->
                                <HBox alignment="CENTER_RIGHT"
                                      spacing="10.0"
                                      AnchorPane.bottomAnchor="8.0"
                                      AnchorPane.rightAnchor="10.0">
                                    <children>
                                        <Button fx:id="btnPosAdd"
                                                text="Thêm chức vụ"
                                                prefHeight="35.0" prefWidth="130.0"
                                                styleClass="action-btn"
                                                stylesheets="@../css/base.css">
                                            <font>
                                                <Font size="14.0"/>
                                            </font>
                                        </Button>
                                        <Button fx:id="btnPosEdit"
                                                text="Sửa chức vụ"
                                                prefHeight="35.0" prefWidth="130.0"
                                                styleClass="action-btn"
                                                stylesheets="@../css/base.css">
                                            <font>
                                                <Font size="14.0"/>
                                            </font>
                                        </Button>
                                        <Button fx:id="btnPosDelete"
                                                text="Xóa chức vụ"
                                                prefHeight="35.0" prefWidth="130.0"
                                                styleClass="action-btn"
                                                stylesheets="@../css/base.css">
                                            <font>
                                                <Font size="14.0"/>
                                            </font>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </children>
                </AnchorPane>
            </bottom>
        </BorderPane>
    </children>
</AnchorPane>

