<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIcon?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="GUI.StatisticController"
            stylesheets="@../css/base.css"
            AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
    <children>
        <VBox spacing="10.0"
              style="-fx-padding: 14 18 0 18; -fx-background-color: #f8f9fa;"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <!-- Tiêu đề -->
            <Label text="Thống kê doanh thu – doanh số" textFill="#006A71"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;">
                <font><Font name="Arial Bold" size="20.0"/></font>
            </Label>

            <!-- Bộ lọc dùng chung -->
            <HBox alignment="CENTER_LEFT" spacing="10.0"
                  style="-fx-background-color: white; -fx-padding: 8 14 8 14;
                         -fx-background-radius: 8; -fx-border-color: #e0e0e0;
                         -fx-border-radius: 8; -fx-border-width: 1;">
                <Label text="Từ ngày" textFill="#006A71"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                <TextField fx:id="fromDate" prefWidth="110.0" style="-fx-font-size: 13px;"
                           promptText="dd/MM/yyyy"/>
                <Label text="Đến ngày" textFill="#006A71"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                <TextField fx:id="toDate" prefWidth="110.0" style="-fx-font-size: 13px;"
                           promptText="dd/MM/yyyy"/>
                <Label text="Xem theo" textFill="#006A71"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                <ComboBox fx:id="viewByCombo" prefWidth="100.0" style="-fx-font-size: 13px;"/>
                <Button fx:id="btnFilter" mnemonicParsing="false"
                        prefHeight="30.0" prefWidth="100.0"
                        styleClass="action-btn" stylesheets="@../css/base.css" text="Lọc">
                    <font><Font size="13.0"/></font>
                    <graphic><FontAwesomeIcon glyphName="SEARCH" styleClass="action-icon"/></graphic>
                </Button>
                <Button fx:id="btnRefresh" mnemonicParsing="false"
                        prefHeight="30.0" prefWidth="110.0"
                        styleClass="action-btn" stylesheets="@../css/base.css" text="Làm mới">
                    <font><Font size="13.0"/></font>
                    <graphic><FontAwesomeIcon glyphName="REFRESH" styleClass="action-icon"/></graphic>
                </Button>
            </HBox>

            <!-- TabPane -->
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     style="-fx-background-color: white;"
                     VBox.vgrow="ALWAYS">

                <!-- ══════════ Tab 1: Tổng quan ══════════ -->
                <Tab text="Tổng quan">
                    <content>
                        <AnchorPane>
                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                                        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                                        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                        style="-fx-background-color: white; -fx-background: white;">
                                <content>
                                    <VBox spacing="14.0"
                                          style="-fx-padding: 14 12 18 12; -fx-background-color: white;">

                                        <!-- KPI Cards – Hàng 1 -->
                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="190.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #9ACBD0; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Tổng doanh thu" textFill="#006A71"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblOverviewRevenue" text="—" textFill="#1F7D84"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label text="trong kỳ" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="190.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #e57373; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Tổng chi phí" textFill="#c62828"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblOverviewCost" text="—" textFill="#e53935"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label text="nhập hàng + lương" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="190.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #81C784; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Lợi nhuận" textFill="#2e7d32"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblOverviewProfit" text="—" textFill="#4CAF50"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label text="trong kỳ" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="160.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #9ACBD0; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Số hóa đơn" textFill="#006A71"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblOverviewInvoiceCount" text="—" textFill="#1F7D84"
                                                       style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                                                <Label text="hóa đơn" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                        </HBox>

                                        <!-- KPI Cards – Hàng 2: Chi tiết chi phí -->
                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="230.0" minHeight="78.0"
                                                  style="-fx-background-color: #fff8f8; -fx-background-radius: 10;
                                                         -fx-border-color: #FFAB91; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 10;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.07), 4, 0, 0, 2);">
                                                <Label text="Tổng tiền nhập hàng" textFill="#BF360C"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblOverviewImportCost" text="—" textFill="#E64A19"
                                                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                                                <Label text="chi phí nhập hàng" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="230.0" minHeight="78.0"
                                                  style="-fx-background-color: #fff8f8; -fx-background-radius: 10;
                                                         -fx-border-color: #EF9A9A; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 10;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.07), 4, 0, 0, 2);">
                                                <Label text="Tổng lương nhân viên" textFill="#B71C1C"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblOverviewSalaryCost" text="—" textFill="#C62828"
                                                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                                                <Label text="chi phí nhân sự" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                        </HBox>

                                        <!-- LineChart: Doanh thu vs Chi nhập hàng -->
                                        <VBox spacing="5.0">
                                            <Label text="Xu hướng doanh thu – chi phí theo kỳ" textFill="#006A71"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                                            <LineChart fx:id="overviewTrendChart"
                                                       prefHeight="260.0" minHeight="260.0" maxHeight="260.0"
                                                       animated="false"
                                                       style="-fx-background-color: transparent;">
                                                <xAxis><CategoryAxis/></xAxis>
                                                <yAxis><NumberAxis label="Triệu đồng"/></yAxis>
                                            </LineChart>
                                        </VBox>

                                        <!-- BarChart: Doanh thu theo danh mục -->
                                        <VBox spacing="5.0">
                                            <Label text="Doanh thu theo danh mục sản phẩm" textFill="#006A71"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                                            <BarChart fx:id="overviewCategoryChart"
                                                      prefHeight="240.0" minHeight="240.0" maxHeight="240.0"
                                                      animated="false" legendVisible="false"
                                                      categoryGap="14.0" barGap="4.0"
                                                      style="-fx-background-color: transparent;">
                                                <xAxis><CategoryAxis/></xAxis>
                                                <yAxis><NumberAxis label="Triệu đồng"/></yAxis>
                                            </BarChart>
                                        </VBox>

                                    </VBox>
                                </content>
                            </ScrollPane>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ══════════ Tab 2: Doanh thu ══════════ -->
                <Tab text="Doanh thu">
                    <content>
                        <AnchorPane>
                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                                        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                                        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                        style="-fx-background-color: white; -fx-background: white;">
                                <content>
                                    <VBox spacing="14.0"
                                          style="-fx-padding: 14 12 18 12; -fx-background-color: white;">

                                        <!-- KPI Cards -->
                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="220.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #9ACBD0; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Tổng doanh thu" textFill="#006A71"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblTotalRevenue" text="—" textFill="#1F7D84"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label text="(hóa đơn hoàn thành)" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="175.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #9ACBD0; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Số hóa đơn" textFill="#006A71"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblTotalInvoices" text="—" textFill="#1F7D84"
                                                       style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                                                <Label text="hóa đơn hoàn thành" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="220.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #9ACBD0; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Trung bình / hóa đơn" textFill="#006A71"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblAvgInvoice" text="—" textFill="#1F7D84"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label text="trên mỗi hóa đơn" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                        </HBox>

                                        <!-- LineChart: Doanh thu theo thời gian -->
                                        <VBox spacing="5.0">
                                            <Label text="Doanh thu theo thời gian" textFill="#006A71"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                                            <LineChart fx:id="revenueLineChart"
                                                       prefHeight="260.0" minHeight="260.0" maxHeight="260.0"
                                                       animated="false" legendVisible="false"
                                                       style="-fx-background-color: transparent;">
                                                <xAxis><CategoryAxis/></xAxis>
                                                <yAxis><NumberAxis label="Triệu đồng"/></yAxis>
                                            </LineChart>
                                        </VBox>

                                        <!-- BarChart: Doanh thu theo danh mục -->
                                        <VBox spacing="5.0">
                                            <Label text="Doanh thu theo danh mục" textFill="#006A71"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                                            <BarChart fx:id="revenueCategoryChart"
                                                      prefHeight="220.0" minHeight="220.0" maxHeight="220.0"
                                                      animated="false" legendVisible="false"
                                                      categoryGap="14.0" barGap="4.0"
                                                      style="-fx-background-color: transparent;">
                                                <xAxis><CategoryAxis/></xAxis>
                                                <yAxis><NumberAxis label="Triệu đồng"/></yAxis>
                                            </BarChart>
                                        </VBox>

                                        <!-- TableView -->
                                        <VBox spacing="6.0">
                                            <Label text="Chi tiết doanh thu theo kỳ" textFill="#006A71"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                                            <TableView fx:id="tblRevenue" prefHeight="230.0"
                                                       styleClass="table-view" stylesheets="@../css/base.css">
                                                <columns>
                                                    <TableColumn fx:id="colRevPeriod" text="Kỳ" prefWidth="180.0"/>
                                                    <TableColumn fx:id="colRevAmount" text="Doanh thu" prefWidth="220.0"/>
                                                    <TableColumn fx:id="colRevCount" text="Số hóa đơn" prefWidth="140.0"/>
                                                </columns>
                                            </TableView>
                                        </VBox>

                                    </VBox>
                                </content>
                            </ScrollPane>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ══════════ Tab 3: Chi ══════════ -->
                <Tab text="Chi">
                    <content>
                        <AnchorPane>
                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                                        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                                        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                        style="-fx-background-color: white; -fx-background: white;">
                                <content>
                                    <VBox spacing="14.0"
                                          style="-fx-padding: 14 12 18 12; -fx-background-color: white;">

                                        <!-- KPI Cards -->
                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="190.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #e57373; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Tổng chi phí" textFill="#c62828"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblTotalCost" text="—" textFill="#e53935"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label text="nhập hàng + lương" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="190.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #e57373; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Chi nhập hàng" textFill="#c62828"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblImportCost" text="—" textFill="#e53935"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label text="tổng giá trị nhập" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="190.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #e57373; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Lương nhân viên" textFill="#c62828"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblSalaryCost" text="—" textFill="#e53935"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold;"/>
                                                <Label text="tổng NET trong kỳ" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="155.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
                                                         -fx-border-color: #9ACBD0; -fx-border-radius: 10;
                                                         -fx-border-width: 1.5; -fx-padding: 12;
                                                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.09), 5, 0, 0, 2);">
                                                <Label text="Số phiếu nhập" textFill="#006A71"
                                                       style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                                                <Label fx:id="lblImportCount" text="—" textFill="#1F7D84"
                                                       style="-fx-font-size: 26px; -fx-font-weight: bold;"/>
                                                <Label text="phiếu nhập hàng" textFill="#888" style="-fx-font-size: 11px;"/>
                                            </VBox>
                                        </HBox>

                                        <!-- BarChart: Chi theo thời gian (2 series) -->
                                        <VBox spacing="5.0">
                                            <Label text="Chi phí theo thời gian (nhập hàng + lương)" textFill="#006A71"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                                            <BarChart fx:id="costTimelineChart"
                                                      prefHeight="260.0" minHeight="260.0" maxHeight="260.0"
                                                      animated="false"
                                                      categoryGap="10.0" barGap="3.0"
                                                      style="-fx-background-color: transparent;">
                                                <xAxis><CategoryAxis/></xAxis>
                                                <yAxis><NumberAxis label="Triệu đồng"/></yAxis>
                                            </BarChart>
                                        </VBox>

                                        <!-- BarChart: Chi theo nhà cung cấp -->
                                        <VBox spacing="5.0">
                                            <Label text="Chi nhập hàng theo nhà cung cấp (Top 10)" textFill="#006A71"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                                            <BarChart fx:id="supplierCostChart"
                                                      prefHeight="240.0" minHeight="240.0" maxHeight="240.0"
                                                      animated="false" legendVisible="false"
                                                      categoryGap="20.0" barGap="4.0"
                                                      style="-fx-background-color: transparent;">
                                                <xAxis><CategoryAxis/></xAxis>
                                                <yAxis><NumberAxis label="Triệu đồng"/></yAxis>
                                            </BarChart>
                                        </VBox>

                                        <!-- TableView chi phí theo tháng -->
                                        <VBox spacing="6.0">
                                            <Label text="Chi tiết chi phí theo tháng" textFill="#006A71"
                                                   style="-fx-font-size: 13px; -fx-font-weight: bold;"/>
                                            <TableView fx:id="tblCost" prefHeight="230.0"
                                                       styleClass="table-view" stylesheets="@../css/base.css">
                                                <columns>
                                                    <TableColumn fx:id="colCostPeriod" text="Tháng" prefWidth="120.0"/>
                                                    <TableColumn fx:id="colCostImport" text="Chi nhập hàng" prefWidth="180.0"/>
                                                    <TableColumn fx:id="colCostSalary" text="Lương nhân viên" prefWidth="180.0"/>
                                                    <TableColumn fx:id="colCostTotal" text="Tổng chi" prefWidth="160.0"/>
                                                </columns>
                                            </TableView>
                                        </VBox>

                                    </VBox>
                                </content>
                            </ScrollPane>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ══════════ Tab 4: Lợi nhuận ══════════ -->
                <Tab text="Lợi nhuận">
                    <content>
                        <AnchorPane>
                            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                                        AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                                        AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                                        style="-fx-background-color: white; -fx-background: white;">
                                <content>
                                    <VBox spacing="14.0"
                                          style="-fx-padding: 14 12 18 12; -fx-background-color: white;">

                                        <!-- KPI Cards -->
                                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                                            <VBox alignment="CENTER" spacing="4.0" prefWidth="190.0" minHeight="90.0"
                                                  style="-fx-background-color: white; -fx-background-radius: 10;
