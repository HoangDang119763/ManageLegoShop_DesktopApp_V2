<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="260.0" prefWidth="450.0"
            styleClass="white-bg"
            stylesheets="@../css/base.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="GUI.DepartmentModalController">
    <children>
        <BorderPane prefHeight="260.0" prefWidth="450.0"
                    style="-fx-border-color: #30bac4; -fx-border-width: 2px;"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0"
                    AnchorPane.topAnchor="0.0">
            <top>
                <AnchorPane prefHeight="60.0" prefWidth="450.0" BorderPane.alignment="CENTER">
                    <children>
                        <Label fx:id="modalName"
                               alignment="CENTER"
                               layoutX="122.0" layoutY="18.0"
                               prefHeight="23.0" prefWidth="250.0"
                               textFill="#30bac4">
                            <font>
                                <Font name="Arial Bold" size="20.0"/>
                            </font>
                        </Label>
                    </children>
                </AnchorPane>
            </top>
            <center>
                <AnchorPane prefHeight="140.0" prefWidth="450.0" BorderPane.alignment="CENTER">
                    <children>
                        <VBox prefHeight="140.0" prefWidth="430.0"
                              stylesheets="@../css/base.css"
                              AnchorPane.bottomAnchor="0.0"
                              AnchorPane.leftAnchor="10.0"
                              AnchorPane.rightAnchor="10.0"
                              AnchorPane.topAnchor="0.0"
                              spacing="10.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label prefHeight="22.0" prefWidth="120.0"
                                               text="Tên phòng ban"
                                               textFill="#30bac4">
                                            <font>
                                                <Font name="Arial Bold" size="16.0"/>
                                            </font>
                                        </Label>
                                        <Label text=":" textFill="#30bac4">
                                            <font>
                                                <Font size="18.0"/>
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtDepartmentName"
                                                   promptText="Tên phòng ban"
                                                   styleClass="textfield-1">
                                            <font>
                                                <Font size="14.0"/>
                                            </font>
                                        </TextField>
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label prefHeight="22.0" prefWidth="120.0"
                                               text="Mô tả"
                                               textFill="#30bac4">
                                            <font>
                                                <Font name="Arial Bold" size="16.0"/>
                                            </font>
                                        </Label>
                                        <Label text=":" textFill="#30bac4">
                                            <font>
                                                <Font size="18.0"/>
                                            </font>
                                        </Label>
                                        <TextField fx:id="txtDescription"
                                                   promptText="Mô tả"
                                                   styleClass="textfield-1">
                                            <font>
                                                <Font size="14.0"/>
                                            </font>
                                        </TextField>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </center>
            <bottom>
                <AnchorPane prefHeight="60.0" prefWidth="450.0" BorderPane.alignment="CENTER">
                    <children>
                        <HBox alignment="CENTER"
                              prefHeight="60.0" prefWidth="450.0"
                              spacing="60.0"
                              AnchorPane.bottomAnchor="0.0"
                              AnchorPane.leftAnchor="80.0"
                              AnchorPane.rightAnchor="80.0"
                              AnchorPane.topAnchor="0.0">
                            <children>
                                <Button fx:id="closeBtn"
                                        mnemonicParsing="false"
                                        prefHeight="26.0" prefWidth="140.0"
                                        styleClass="action-btn"
                                        stylesheets="@../css/base.css"
                                        text="Thoát"/>
                                <Button fx:id="saveBtn"
                                        mnemonicParsing="false"
                                        prefHeight="26.0" prefWidth="140.0"
                                        styleClass="action-btn"
                                        stylesheets="@../css/base.css"
                                        text="Lưu"/>
                            </children>
                        </HBox>
                    </children>
                </AnchorPane>
            </bottom>
        </BorderPane>
    </children>
</AnchorPane>

